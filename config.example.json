        "^https?://127\\.0\\.0\\.1(?::\\d+)?$",
        "^https?://192\\.168\\..*$"
    ],
    "wsgi_server": "waitress",
    "waitress_threads": 4,
    "gunicorn_workers": 2,
    "gunicorn_threads": 4
}
